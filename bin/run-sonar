#!/usr/bin/env bash
# Wrapper script to run sonar-scanner with token auto-loading

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Read project key from sonar-project.properties
WHITESPACE_CHARS='[:space:]'
PROJECT_KEY=$(grep 'sonar.projectKey=' "$SCRIPT_DIR/sonar-project.properties" | cut -d= -f2 | tr -d "$WHITESPACE_CHARS")

# Try to load token in order:
# 1. .env file in project root
# 2. sonar-token-manager if available
# 3. Environment variable SONAR_TOKEN

if [[ -f "$PROJECT_ROOT/.env" ]]; then
  set +u
  # shellcheck disable=SC1090
  source "$PROJECT_ROOT/.env"
  set -u
  echo "✓ Loaded token from .env"
elif command -v sonar-token-manager &>/dev/null; then
  if SONAR_TOKEN=$(sonar-token-manager get "$PROJECT_KEY" 2>/dev/null); then
    export SONAR_TOKEN
    echo "✓ Loaded token from credentials manager"
  fi
fi

# Run the actual sonar-scanner script
"$SCRIPT_DIR/sonar-scanner.sh" "$@"
