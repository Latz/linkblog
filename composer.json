{
    "name": "latz/linkdigest",
    "description": "LinkDigest WordPress plugin – curated link roundups",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "LinkDigest\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LinkDigest\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "pestphp/pest": "^4.0",
        "brain/monkey": "^2.7",
        "yoast/phpunit-polyfills": "^4.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest --testsuite=Unit",
        "test:unit": "pest --testsuite=Unit",
        "test:integration": "pest --testsuite=Integration --bootstrap tests/bootstrap-integration.php",
        "i18n:pot": "wp i18n make-pot . languages/linkdigest.pot --domain=linkdigest --exclude=vendor,node_modules,tests,bin,dist,chrome-extension,memory"
    }
}
